@page "/artists"


@attribute [Authorize(Policy = "ValidTokenOnly")]

@inject IArtistService ArtistApiService

<section>
    <h2>Artists</h2>

    <EditForm Model="_artistFilter" OnValidSubmit="() => FetchArtists(_page)">
        <div>
            <label for="Name">Name</label>
            <InputText @bind-Value="_artistFilter.Name" type="text" id="Name" />
        </div>

        <div>
            <button type="submit">Filter</button>
        </div>
    </EditForm>

    @if (_artistsResults is not null && _artistsResults.Count > 0)
    {
        <ul>
            @foreach (var artistResult in _artistsResults)
            {
                <li>@artistResult.Name</li>
            }
        </ul>
    }
    else
    {
        if(_artistsResults is null)
        {
            <p>Loading... </p>
        } 
        else
        {
            <p>There are no artists</p>
        }
    }

    <Pagination Page="_page" PageSize="_pageSize" TotalCount="_totalCount" PageChanged="FetchArtists"/>
</section>


@code {
    private ArtistFilter _artistFilter = new ArtistFilter { };

    private int _page = 1;
    private int _pageSize = 24;
    private int _totalCount;

    private IList<ArtistResult>? _artistsResults;

    protected override async Task OnInitializedAsync()
    {
        await FetchArtists(_page);

        await base.OnInitializedAsync();
    }

    private async Task FetchArtists(int page)
    {
        var serviceResult = await ArtistApiService.GetAll(new PaginationRequest { Page = (uint)page, PageSize = (uint)_pageSize }, _artistFilter);

        _page = (int)serviceResult.Page;
        _pageSize = (int)serviceResult.PageSize;
        _totalCount = (int)serviceResult.TotalCount;

        _artistsResults = serviceResult.Data;
    }
}
